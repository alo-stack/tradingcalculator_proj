{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flutter: Run on Chrome",
            "type": "shell",
            "command": "flutter",
            "args": [
                "run",
                "-d",
                "chrome"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Launching.*",
                    "endsPattern": "^Application finished\\.|^.*error.*"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ]
}
